      {
        "type": "text",
        "content": "\u4e0d\u7ba1\u4f60\u505a\u4ec0\u4e48\uff0c\u7ec8\u7a76\u8981\u8bf4\u670d\u522b\u4eba\u76f8\u4fe1\u4f60\u3002\u6e05\u6670\u8868\u8fbe\u7684\u524d\u63d0\u662f\u6e05\u6670\u601d\u8003\u3002\u5356\u4f60\u771f\u6b63\u76f8\u4fe1\u7684\u4e1c\u897f\uff0c\u8fd9\u662f\u6700\u597d\u7684\u9500\u552e\u5fc3\u6cd5\uff0c\u4e5f\u662f\u6700\u5bb9\u6613\u88ab\u5ffd\u89c6\u7684\u3002"
