      {
        "type": "text",
        "content": "HOW TO BE SUCCESSFUL"
      },
      {
        "type": "text",
        "content": "01"
      },
      {
        "type": "text",
        "content": "Compound Yourself"
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": "ORIGINAL POINT"
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": "Look for exponential curves everywhere. Aim for your life to follow an ever-increasing up-and-to-the-right trajectory. Long-term thinking is the biggest competitive advantage."
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
