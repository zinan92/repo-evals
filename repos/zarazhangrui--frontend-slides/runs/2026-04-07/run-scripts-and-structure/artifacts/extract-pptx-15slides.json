        "type": "text",
        "content": "\u806a\u660e\u4eba\u6700\u5e38\u89c1\u7684\u6d6a\u8d39\uff0c\u662f\u628a\u7cbe\u529b\u5206\u6563\u5728\u4e0d\u91cd\u8981\u7684\u4e8b\u60c5\u4e0a\u3002\u5148\u60f3\u6e05\u695a\u505a\u4ec0\u4e48\uff0c\u518d\u8c08\u600e\u4e48\u505a\u3002\u6267\u884c\u529b\u7684\u524d\u63d0\u662f\u4e13\u6ce8\u529b\u3002"
