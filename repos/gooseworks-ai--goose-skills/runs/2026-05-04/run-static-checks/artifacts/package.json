{
  "name": "goose-skills",
  "version": "1.0.1",
  "description": "GTM skills for Claude Code — install with npx goose-skills install <slug>",
  "bin": {
    "goose-skills": "./bin/goose-skills.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/athina-ai/goose-skills"
  },
  "scripts": {
    "test": "node --test test/goose-skills-targets.test.js test/goose-skills-packs.test.js scripts/__tests__/build-index.test.js scripts/__tests__/validate-skills.test.js",
    "test:eval": "node test/run-eval.js",
    "test:eval:run": "node test/run-eval.js",
    "test:eval:check": "node test/evaluate-run.js",
    "test:eval:generate": "node scripts/generate-eval-prompts.js",
    "build:index": "node scripts/build-index.js",
    "validate:skills": "node scripts/validate-skills.js",
    "ci": "npm run validate:skills && npm run build:index && npm test"
  },
  "keywords": [
    "claude-code",
    "skills",
    "gtm",
    "sales",
    "marketing",
    "scraping"
  ],
  "author": "Athina AI",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.6"
  }
}
